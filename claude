<!DOCTYPE html>
<html lang="ko">
<head>
  <meta charset="UTF-8"/>
  <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
  <title>Fur Widget</title>
  <script src="https://cdnjs.cloudflare.com/ajax/libs/react/18.2.0/umd/react.production.min.js"></script>
  <script src="https://cdnjs.cloudflare.com/ajax/libs/react-dom/18.2.0/umd/react-dom.production.min.js"></script>
  <script src="https://cdnjs.cloudflare.com/ajax/libs/babel-standalone/7.23.2/babel.min.js"></script>
  <link href="https://fonts.googleapis.com/css2?family=Nunito:wght@700;800;900&display=swap" rel="stylesheet"/>
  <style>
    * { box-sizing: border-box; margin: 0; padding: 0; }
    html, body, #root { width: 100%; height: 100%; }
    input[type=range]::-webkit-slider-thumb { opacity: 0; }
    input[type=range]::-moz-range-thumb { opacity: 0; }
    @keyframes blink { 0%,49%{opacity:1} 50%,100%{opacity:.2} }
    @keyframes fl { 0%,100%{transform:translateY(0)} 50%{transform:translateY(-5px)} }
  </style>
</head>
<body>
<div id="root"></div>
<svg width="0" height="0" style="position:absolute;overflow:hidden">
  <defs>
    <filter id="fz" x="-15%" y="-15%" width="130%" height="130%">
      <feTurbulence type="fractalNoise" baseFrequency="0.07" numOctaves="4" seed="9" result="n"/>
      <feDisplacementMap in="SourceGraphic" in2="n" scale="9" xChannelSelector="R" yChannelSelector="G" result="d"/>
      <feGaussianBlur in="d" stdDeviation="0.7"/>
    </filter>
    <filter id="fz2" x="-20%" y="-20%" width="140%" height="140%">
      <feTurbulence type="fractalNoise" baseFrequency="0.075" numOctaves="5" seed="5" result="n"/>
      <feDisplacementMap in="SourceGraphic" in2="n" scale="14" xChannelSelector="R" yChannelSelector="G" result="d"/>
      <feGaussianBlur in="d" stdDeviation="1.1"/>
    </filter>
  </defs>
</svg>

<script type="text/babel">
const { useState, useEffect, useRef } = React;

const paintFur = (canvas) => {
  const ctx = canvas.getContext("2d"), W = canvas.width, H = canvas.height;
  ctx.fillStyle = "#f5b8c4";
  ctx.fillRect(0, 0, W, H);
  for (let i = 0; i < 5500; i++) {
    const x = Math.random()*W, y = Math.random()*H, len = 9 + Math.random()*18;
    const a = -Math.PI/2 + (Math.random()-.5)*1.6, cv = (Math.random()-.5)*.7;
    const cx = x+Math.cos(a+cv)*len*.5, cy = y+Math.sin(a+cv)*len*.5;
    const ex = x+Math.cos(a)*len, ey = y+Math.sin(a)*len;
    const g = ctx.createLinearGradient(x,y,ex,ey);
    g.addColorStop(0, "#a03868cc");
    g.addColorStop(.45, "#f5b8c4aa");
    g.addColorStop(1, "#fff0f300");
    ctx.beginPath(); ctx.moveTo(x,y); ctx.quadraticCurveTo(cx,cy,ex,ey);
    ctx.strokeStyle = g;
    ctx.lineWidth = .5 + Math.random()*1.1;
    ctx.lineCap = "round";
    ctx.globalAlpha = .55 + Math.random()*.45;
    ctx.stroke();
  }
  ctx.globalAlpha = 1;
};

function FurBtn({ icon, label, on, onClick }) {
  const [pr, setPr] = useState(false);
  return (
    <button
      title={label}
      onMouseDown={() => setPr(true)}
      onMouseUp={() => setPr(false)}
      onMouseLeave={() => setPr(false)}
      onClick={onClick}
      style={{
        width:58, height:58, borderRadius:"50%", border:"none", cursor:"pointer", fontSize:22,
        background: on
          ? "radial-gradient(circle at 38% 32%,#f9d0d8,#f0a0b8 55%,#e07090)"
          : "radial-gradient(circle at 38% 32%,#fff5f7,#fce4ea 40%,#f5b8c4)",
        boxShadow: pr
          ? "0 2px 4px #e899b060,inset 0 3px 8px #c0607080"
          : "0 6px 18px #e899b055,0 2px 4px #d0708060,inset 0 -4px 10px #e07090,inset 0 5px 14px #fff8facc",
        filter:"url(#fz2)",
        transform: pr ? "scale(0.92) translateY(2px)" : "scale(1)",
        transition: "all 0.15s cubic-bezier(.34,1.56,.64,1)",
        display:"flex", alignItems:"center", justifyContent:"center"
      }}
    >{icon}</button>
  );
}

function FurSlider({ val, set, ico, lbl }) {
  return (
    <div>
      <div style={{display:"flex",justifyContent:"space-between",marginBottom:6}}>
        <span style={{fontFamily:"Nunito,sans-serif",fontSize:12,color:"#c06078",fontWeight:700}}>{ico} {lbl}</span>
        <span style={{fontFamily:"Nunito,sans-serif",fontSize:12,color:"#e07090",fontWeight:800}}>{val}%</span>
      </div>
      <div style={{
        position:"relative", height:16, borderRadius:10,
        background:"radial-gradient(ellipse at 30% 40%,#fce4ea,#f5b8c4)",
        boxShadow:"0 3px 8px #e899b040,inset 0 3px 6px #d0708040",
        filter:"url(#fz)"
      }}>
        <div style={{
          position:"absolute", left:0, top:0, height:"100%",
          width:`${val}%`, borderRadius:10,
          background:"radial-gradient(ellipse at 30% 40%,#f9aac0,#e0607a)"
        }}/>
        <input type="range" min={0} max={100} value={val}
          onChange={e => set(+e.target.value)}
          style={{position:"absolute",inset:0,width:"100%",height:"100%",opacity:0,cursor:"pointer",margin:0}}
        />
      </div>
    </div>
  );
}

function FurToggle({ on, set, label }) {
  return (
    <div onClick={() => set(!on)} style={{display:"flex",alignItems:"center",gap:10,cursor:"pointer"}}>
      <div style={{
        width:54, height:30, borderRadius:15, position:"relative", transition:"all .3s",
        background: on
          ? "radial-gradient(ellipse at 30% 40%,#f9aac0,#e0607a)"
          : "radial-gradient(ellipse at 30% 40%,#fce4ea,#f5b8c4)",
        boxShadow:"0 4px 10px #e899b060,inset 0 -3px 8px #d0708050,inset 0 3px 8px #fff0f3cc",
        filter:"url(#fz)"
      }}>
        <div style={{
          position:"absolute", top:3, left: on ? 27 : 3,
          width:24, height:24, borderRadius:"50%",
          transition:"left .3s cubic-bezier(.34,1.56,.64,1)",
          background:"radial-gradient(circle at 35% 35%,#fff,#fce4ea 60%,#f5b8c4)",
          boxShadow:"0 3px 8px #e899b080,inset 0 2px 4px #fff"
        }}/>
      </div>
      <span style={{fontFamily:"Nunito,sans-serif",fontSize:13,color:"#c06078",fontWeight:700}}>{label}</span>
    </div>
  );
}

const CARD = {
  borderRadius:28,
  background:"radial-gradient(ellipse at 30% 28%,#fff6f8,#fce4ea 38%,#f5b8c4)",
  boxShadow:"0 10px 30px #e899b044,0 4px 12px #d0708044,inset 0 -6px 16px #e07090,inset 0 7px 20px #fff8faee,inset 0 2px 5px #fff",
  filter:"url(#fz)", padding:"18px 20px", position:"relative"
};
const SHIM = {
  position:"absolute", inset:0, borderRadius:28,
  background:"radial-gradient(ellipse at 25% 20%,#ffffffcc,transparent 55%)",
  pointerEvents:"none", zIndex:10
};
const INNER = { position:"relative", zIndex:5 };
const LBL = {
  fontFamily:"Nunito,sans-serif", fontSize:11, color:"#e07090",
  fontWeight:800, marginBottom:14, letterSpacing:1.5, textTransform:"uppercase"
};

function App() {
  const bgRef = useRef();
  const [tick, setTick] = useState(new Date());
  const [br, setBr] = useState(72), [vol, setVol] = useState(55);
  const [wifi, setWifi] = useState(true), [bt, setBt] = useState(true);
  const [dnd, setDnd] = useState(false), [dark, setDark] = useState(false);

  useEffect(() => {
    const i = setInterval(() => setTick(new Date()), 1000);
    return () => clearInterval(i);
  }, []);

  useEffect(() => {
    const c = bgRef.current;
    if (!c) return;
    const render = () => {
      const r = devicePixelRatio || 1;
      c.width = c.offsetWidth * r;
      c.height = c.offsetHeight * r;
      paintFur(c);
    };
    render();
    window.addEventListener("resize", render);
    return () => window.removeEventListener("resize", render);
  }, []);

  const hh = tick.getHours().toString().padStart(2,"0");
  const mm = tick.getMinutes().toString().padStart(2,"0");
  const ss = tick.getSeconds().toString().padStart(2,"0");
  const ds = tick.toLocaleDateString("ko-KR",{month:"long",day:"numeric",weekday:"short"});

  return (
    <div style={{minHeight:"100vh",display:"flex",alignItems:"center",justifyContent:"center",position:"relative",overflow:"hidden"}}>
      <canvas ref={bgRef} style={{position:"fixed",inset:0,width:"100%",height:"100%",objectFit:"cover"}}/>

      <div style={{position:"relative",zIndex:1,width:340,display:"flex",flexDirection:"column",gap:16,padding:20}}>

        {/* 시계 */}
        <div style={{...CARD, animation:"fl 4s ease-in-out infinite"}}>
          <div style={SHIM}/>
          <div style={{...INNER, textAlign:"center"}}>
            <div style={{fontSize:60,fontWeight:900,color:"#c06078",lineHeight:1,letterSpacing:-3,textShadow:"0 3px 10px #e07090aa,0 1px 0 #fff5f7",fontFamily:"Nunito,sans-serif"}}>
              {hh}<span style={{animation:"blink 1s infinite",display:"inline-block"}}>:</span>{mm}
            </div>
            <div style={{fontSize:13,color:"#e07090",fontWeight:800,marginTop:4,fontFamily:"Nunito,sans-serif"}}>{ds}</div>
            <div style={{fontSize:11,color:"#d08090",fontWeight:700,marginTop:2,fontFamily:"Nunito,sans-serif",opacity:.6}}>{ss}초</div>
          </div>
        </div>

        {/* 퀵 컨트롤 */}
        <div style={CARD}><div style={SHIM}/><div style={INNER}>
          <div style={LBL}>✦ Quick Controls</div>
          <div style={{display:"grid",gridTemplateColumns:"repeat(4,1fr)",gap:12,justifyItems:"center"}}>
            <FurBtn icon="✈️" label="에어플레인"/>
            <FurBtn icon="📶" label="WiFi" on={wifi} onClick={() => setWifi(v=>!v)}/>
            <FurBtn icon="🔵" label="Bluetooth" on={bt} onClick={() => setBt(v=>!v)}/>
            <FurBtn icon="🌙" label="방해금지" on={dnd} onClick={() => setDnd(v=>!v)}/>
            <FurBtn icon="🔦" label="손전등"/>
            <FurBtn icon="⏱️" label="타이머"/>
            <FurBtn icon="📷" label="카메라"/>
            <FurBtn icon="⚙️" label="설정"/>
          </div>
        </div></div>

        {/* 슬라이더 */}
        <div style={CARD}><div style={SHIM}/><div style={INNER}>
          <div style={LBL}>✦ 조절</div>
          <div style={{display:"flex",flexDirection:"column",gap:16}}>
            <FurSlider val={br} set={setBr} ico="☀️" lbl="밝기"/>
            <FurSlider val={vol} set={setVol} ico="🔊" lbl="볼륨"/>
          </div>
        </div></div>

        {/* 토글 */}
        <div style={CARD}><div style={SHIM}/><div style={INNER}>
          <div style={LBL}>✦ 설정</div>
          <div style={{display:"flex",flexDirection:"column",gap:14}}>
            <FurToggle on={wifi} set={setWifi} label="Wi-Fi"/>
            <FurToggle on={bt} set={setBt} label="Bluetooth"/>
            <FurToggle on={dnd} set={setDnd} label="방해 금지 모드"/>
            <FurToggle on={dark} set={setDark} label="다크 모드"/>
          </div>
        </div></div>

      </div>
    </div>
  );
}

ReactDOM.createRoot(document.getElementById("root")).render(<App/>);
</script>
</body>
</html>
